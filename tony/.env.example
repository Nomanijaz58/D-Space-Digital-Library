# DSpace Docker Compose - Environment
# Copy to .env and set values. Never commit .env to version control.
#
# Required
POSTGRES_PASSWORD=changeme_use_strong_password

# Optional: PostgreSQL
POSTGRES_DB=dspace
POSTGRES_USER=dspace
POSTGRES_VERSION=15
# Host to bind (e.g. 127.0.0.1); omit or use 0.0.0.0 to expose on all interfaces
POSTGRES_BIND=127.0.0.1

# Optional: DSpace
DSPACE_VER=latest-test
DOCKER_REGISTRY=docker.io
DOCKER_OWNER=dspace
DSPACE_SITE_NAME=DSpace
# Must match DSPACE_NETWORK_SUBNET (e.g. 172.23.0 for 172.23.0.0/16)
DSPACE_TRUSTED_IPRANGES=172.23.0
# Host to bind for server and debug ports; use 0.0.0.0 to expose on all interfaces
DSPACE_SERVER_BIND=127.0.0.1
DSPACE_DEBUG_BIND=127.0.0.1

# Optional: Solr
SOLR_VER=9.8
SOLR_BIND=127.0.0.1

# Optional: Build context (when using source tree)
# DSPACE_BUILD_CONTEXT=.
# DSPACE_DOCKERFILE=Dockerfile.test
# DSPACE_SOLR_CONTEXT=./dspace/src/main/docker/dspace-solr
# DSPACE_SOLR_CONFIGS=./dspace/solr

# Optional: Network (must match first octets in DSPACE_TRUSTED_IPRANGES)
# DSPACE_NETWORK_SUBNET=172.23.0.0/16
