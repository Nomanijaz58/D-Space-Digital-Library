# Solr for Render with proper port binding and DSpace schemas
FROM solr:8.11

# Set environment variables for Render
ENV PORT=8983
ENV SOLR_PORT=8983

USER root
# Install curl for troubleshooting
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# DSpace solrconfig.xml hardcodes looking in /opt/solr/modules/analysis-extras/lib/
# We create this path and populate it to satisfy the <lib> tags.
RUN mkdir -p /opt/solr/modules/analysis-extras/lib/

# Pre-create Solr core templates in a non-volume path
# This survives Render persistent disk mounts which shadow /var/solr/data
RUN mkdir -p /opt/solr/core-templates/search/conf /opt/solr/core-templates/search/lib \
             /opt/solr/core-templates/statistics/conf /opt/solr/core-templates/statistics/lib \
             /opt/solr/core-templates/authority/conf /opt/solr/core-templates/authority/lib \
             /opt/solr/core-templates/oai/conf /opt/solr/core-templates/oai/lib

# Copy DSpace Solr configuration files to templates
COPY dspace/solr/search/conf/ /opt/solr/core-templates/search/conf/
COPY dspace/solr/statistics/conf/ /opt/solr/core-templates/statistics/conf/
COPY dspace/solr/authority/conf/ /opt/solr/core-templates/authority/conf/
COPY dspace/solr/oai/conf/ /opt/solr/core-templates/oai/conf/

# Collect all ICU and analysis-extras jars. 
# We copy them to THREE places for absolute certainty:
# 1. /opt/solr/modules/analysis-extras/lib/ (Expected by DSpace <lib> tags)
# 2. /opt/solr/core-templates/*/lib/ (Core-specific lib folders in template)
# 3. /opt/solr/server/solr-webapp/webapp/WEB-INF/lib/ (Global Solr classpath)

RUN wget -qO /opt/solr/modules/analysis-extras/lib/icu4j-68.2.jar "https://repo1.maven.org/maven2/com/ibm/icu/icu4j/68.2/icu4j-68.2.jar" && \
    wget -qO /opt/solr/modules/analysis-extras/lib/lucene-analyzers-icu-8.11.4.jar "https://repo1.maven.org/maven2/org/apache/lucene/lucene-analyzers-icu/8.11.4/lucene-analyzers-icu-8.11.4.jar" && \
    wget -qO /opt/solr/modules/analysis-extras/lib/solr-analysis-extras-8.11.4.jar "https://repo1.maven.org/maven2/org/apache/solr/solr-analysis-extras/8.11.4/solr-analysis-extras-8.11.4.jar"

# Handle 'analysis' vs 'analyzers' naming mismatch for DSpace regex
RUN cp /opt/solr/modules/analysis-extras/lib/lucene-analyzers-icu-8.11.4.jar /opt/solr/modules/analysis-extras/lib/lucene-analysis-icu-8.11.4.jar

# Copy to core-specific lib folders in templates
RUN cp /opt/solr/modules/analysis-extras/lib/*.jar /opt/solr/core-templates/search/lib/ && \
    cp /opt/solr/modules/analysis-extras/lib/*.jar /opt/solr/core-templates/statistics/lib/ && \
    cp /opt/solr/modules/analysis-extras/lib/*.jar /opt/solr/core-templates/authority/lib/ && \
    cp /opt/solr/modules/analysis-extras/lib/*.jar /opt/solr/core-templates/oai/lib/

# Copy to global webapp lib folder (Brute-force fix for ClassNotFoundException)
RUN cp /opt/solr/modules/analysis-extras/lib/*.jar /opt/solr/server/solr-webapp/webapp/WEB-INF/lib/

# Create core.properties files in templates
RUN echo "name=search" > /opt/solr/core-templates/search/core.properties && \
    echo "name=statistics" > /opt/solr/core-templates/statistics/core.properties && \
    echo "name=authority" > /opt/solr/core-templates/authority/core.properties && \
    echo "name=oai" > /opt/solr/core-templates/oai/core.properties

# Ensure Solr user owns all data, templates, modules, and the webapp lib additions
RUN chown -R solr:solr /var/solr/data && \
    chown -R solr:solr /opt/solr/core-templates && \
    chown -R solr:solr /opt/solr/modules && \
    chown solr:solr /opt/solr/server/solr-webapp/webapp/WEB-INF/lib/*.jar

USER solr

# Copy and prepare the entrypoint script
COPY solr-entrypoint.sh /opt/solr/bin/solr-entrypoint.sh
USER root
RUN chmod +x /opt/solr/bin/solr-entrypoint.sh
USER solr

EXPOSE 8983

CMD ["/opt/solr/bin/solr-entrypoint.sh"]
